# 数据库
DATABASE_URL="file:./dev.db"

# 迁移到 PostgreSQL 时使用此连接串, 然后运行 npx prisma db push
# DATABASE_URL="postgresql://user:password@localhost:5432/vocational_colleges?schema=public"

# LLM API (OpenAI 兼容格式: DeepSeek/通义千问/Kimi/OpenAI 均可)
# 支持所有兼容 /v1/chat/completions 接口的服务
LLM_API_KEY=sk-your-key-here
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
# 其他常用配置示例:
# 通义千问: LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions  LLM_MODEL=qwen-max
# Kimi:      LLM_API_URL=https://api.moonshot.cn/v1/chat/completions              LLM_MODEL=moonshot-v1-8k
# OpenAI:    LLM_API_URL=https://api.openai.com/v1/chat/completions               LLM_MODEL=gpt-4o
